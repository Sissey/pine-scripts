// Keltner Breakout Strategy
// Volatility breakout with ATR-based stops and R-multiple targets.
// © Atlas Algo Labs — for backtesting/education only. Not financial advice.
//@version=5
strategy("Keltner Breakout Strategy", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=5,
     commission_type=strategy.commission.percent,
     commission_value=0.05)

// ── Inputs ─────────────────────────────────────────────────────────────
grpK   = "Keltner Channel"
kcLen  = input.int(20,   "EMA Length",     minval=1,   group=grpK)
kcMult = input.float(2.0, "ATR Multiplier", step=0.25, group=grpK)
grpR   = "Risk"
atrLen  = input.int(14,   "ATR Length",           group=grpR)
slMult  = input.float(1.5, "Stop Loss (x ATR)",   step=0.25, group=grpR)
tpR     = input.float(2.0, "Take Profit (R mult)", step=0.25, group=grpR)
grpF    = "Filters"
useTrend  = input.bool(true, "Only trade with 200 EMA trend", group=grpF)
allowLong  = input.bool(true, "Allow longs",  group=grpF)
allowShort = input.bool(true, "Allow shorts", group=grpF)

// ── Calculations ───────────────────────────────────────────────────────
basis  = ta.ema(close, kcLen)
rangeA = ta.atr(atrLen)
upperK = basis + rangeA * kcMult
lowerK = basis - rangeA * kcMult
ema200 = ta.ema(close, 200)

longSignal  = ta.crossover(close, upperK)  and (not useTrend or close > ema200) and allowLong
shortSignal = ta.crossunder(close, lowerK) and (not useTrend or close < ema200) and allowShort

// ── Entries & exits ────────────────────────────────────────────────────
if longSignal and strategy.position_size == 0
    slDist = rangeA * slMult
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=close - slDist, limit=close + slDist * tpR)

if shortSignal and strategy.position_size == 0
    slDist = rangeA * slMult
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=close + slDist, limit=close - slDist * tpR)

// ── Plots ──────────────────────────────────────────────────────────────
plot(basis,  "Basis",  color=color.new(color.gray, 40))
pU = plot(upperK, "Upper", color=color.new(color.teal, 40))
pL = plot(lowerK, "Lower", color=color.new(color.teal, 40))
fill(pU, pL, color=color.new(color.teal, 95))
plot(ema200, "EMA 200", color=color.new(color.orange, 0), linewidth=2)

plotshape(longSignal,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(shortSignal, "Short", shape.triangledown, location.abovebar, color.red,   size=size.small)

// ── Alerts ─────────────────────────────────────────────────────────────
alertcondition(longSignal,  "Long Breakout",  "Keltner long breakout on {{ticker}}")
alertcondition(shortSignal, "Short Breakout", "Keltner short breakout on {{ticker}}")
